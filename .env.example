# Claude
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-7

# OpenAI (used by the LiveKit agent for Realtime API)
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin

# LiveKit Cloud — create a project at https://cloud.livekit.io
# Both the Next.js app AND the Python agent need these
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Where the agent calls back to for Claude evaluation
# (Next.js /api/evaluate endpoint)
NEXT_PUBLIC_APP_URL=http://localhost:3000
